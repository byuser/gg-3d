{
  "name": "good-game-3d",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Good Game 3D — a third-person browser action-RPG built on Babylon.js, shipped as a static GitHub Pages site.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,css}\" \"test/**/*.js\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"test/**/*.js\" \"*.{js,json,md}\"",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.2",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
